# Android release signing — COPY this file to `key.properties` (same folder) and
# fill in your real values. key.properties is gitignored (never committed).
#
# Then build the signed AAB from client/android with:
#   ./gradlew bundleRelease
# Output: app/build/outputs/bundle/release/app-release.aab
#
# storeFile is relative to client/android/ (the keystore already lives there).
storeFile=hockia-release-key.jks
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=YOUR_KEY_ALIAS
keyPassword=YOUR_KEY_PASSWORD
