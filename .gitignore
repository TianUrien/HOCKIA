# Environment and Secrets
.env
.env.local
.env.*.local

# Supabase temporary files
supabase/.temp/
supabase/supabase/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/*
# Allow team-wide VSCode config. Personal preferences should still
# go in a per-user settings layer; this file silences false-positive
# Edge Tools linter warnings that don't reflect the project's actual
# quality bar (npm run lint is the source of truth).
# Note: must be `.vscode/*` not `.vscode/`, because git won't list
# contents of an ignored directory so an exception inside it has
# no effect.
!.vscode/settings.json
.idea/

# Dependencies
node_modules/

# Build outputs
dist/
client/dist/
.vite/
client/.vite/

# Android signing keys (NEVER commit)
*.jks
*.keystore
key.properties

# iOS build artifacts
client/ios/App/App/public/
client/ios/App/Pods/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
**/xcshareddata/swiftpm/
DerivedData/

# Test coverage
coverage/
client/coverage/

# Logs
*.log
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
